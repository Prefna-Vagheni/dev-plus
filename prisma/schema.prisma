// Prisma schema for DevPulse with Better Auth
// Database: PostgreSQL 15+

generator client {
  provider = "prisma-client-js"
  engineType = "library" 
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Better Auth Models (Corrected)
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified") // Changed from DateTime? to Boolean
  name          String?
  image         String?
  
  // GitHub specific fields
  githubId       String?  @unique @map("github_id")
  githubUsername String?  @unique @map("github_username")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  accounts       Account[]
  sessions       Session[]
  settings       UserSettings?
  repositories   Repository[]
  activityEvents ActivityEvent[]
  dailyStats     DailyStats[]
  aiInsights     AIInsight[]
  apiKeys        ApiKey[]

  @@map("users")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")    // Corrected name
  providerId            String    @map("provider_id")   // Corrected name
  accessToken           String?   @map("access_token")  @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")      @db.Text
  createdAt             DateTime  @default(now())       @map("created_at")
  updatedAt             DateTime  @updatedAt            @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId]) // Updated unique constraint
  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime @map("expires_at")
  token     String   @unique @map("token") // Corrected from sessionToken
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address") // Required field
  userAgent String?  @map("user_agent") // Required field
  userId    String   @map("user_id")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Better Auth uses this model, not "VerificationToken"
model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("verification")
}



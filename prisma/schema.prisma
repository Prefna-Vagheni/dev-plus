// ============================================
// User Settings & Preferences
// ============================================

model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  
  // Display preferences
  timezone  String   @default("UTC")
  theme     String   @default("system") // 'light', 'dark', 'system'
  
  // Notifications
  notificationsEnabled Boolean @default(true) @map("notifications_enabled")
  emailDigest          Boolean @default(true) @map("email_digest")
  
  // Privacy
  publicProfile Boolean @default(false) @map("public_profile")
  
  // Sync settings
  autoSyncEnabled Boolean @default(true) @map("auto_sync_enabled")
  syncFrequency   String  @default("daily") // 'hourly', 'daily', 'manual'
  
  // Additional preferences (flexible JSON)
  preferences Json @default("{}")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ============================================
// GitHub Data
// ============================================

model Repository {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  
  // GitHub data
  githubRepoId   String   @map("github_repo_id")
  name           String
  fullName       String   @map("full_name")
  description    String?  @db.Text
  isPrivate      Boolean  @default(false) @map("is_private")
  language       String?
  stars          Int      @default(0)
  forks          Int      @default(0)
  
  // Activity tracking
  lastActivityAt DateTime? @map("last_activity_at")
  lastSyncAt     DateTime? @map("last_sync_at")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, githubRepoId])
  @@index([userId, lastActivityAt])
  @@map("repositories")
}

// ============================================
// Activity Events (Time-series data)
// ============================================

enum EventType {
  COMMIT
  PULL_REQUEST
  ISSUE
  CODE_REVIEW
  CODE_SESSION
  RELEASE
  CUSTOM
}

enum EventSource {
  GITHUB
  VSCODE
  MANUAL
  API
}

model ActivityEvent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  
  // Event metadata
  eventType EventType @map("event_type")
  source    EventSource
  
  // Event data (flexible JSON for different event types)
  eventData Json @map("event_data")
  
  // Additional fields
  repositoryName String? @map("repository_name")
  language       String?
  durationSeconds Int?   @map("duration_seconds")
  
  // Timing
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt(sort: Desc)])
  @@index([userId, eventType, occurredAt])
  @@index([occurredAt])
  @@map("activity_events")
}

// ============================================
// Aggregated Daily Statistics
// ============================================

model DailyStats {
  id      String @id @default(cuid())
  userId  String @map("user_id")
  
  // Date for this stats record
  statDate DateTime @map("stat_date") @db.Date
  
  // Activity counts
  totalCommits       Int @default(0) @map("total_commits")
  totalPullRequests  Int @default(0) @map("total_pull_requests")
  totalIssues        Int @default(0) @map("total_issues")
  totalCodeReviews   Int @default(0) @map("total_code_reviews")
  
  // Time tracking
  codingTimeSeconds Int @default(0) @map("coding_time_seconds")
  
  // Language breakdown (JSON: {"TypeScript": 3600, "Python": 1800})
  languages Json @default("{}")
  
  // Repository activity (JSON: ["repo1", "repo2"])
  activeRepositories Json @default("[]") @map("active_repositories")
  
  // Lines of code
  linesAdded   Int @default(0) @map("lines_added")
  linesDeleted Int @default(0) @map("lines_deleted")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, statDate])
  @@index([userId, statDate(sort: Desc)])
  @@map("daily_stats")
}

// ============================================
// AI Insights & Analysis
// ============================================

enum InsightType {
  WEEKLY_SUMMARY
  CODE_PATTERN_ANALYSIS
  PRODUCTIVITY_TREND
  RECOMMENDATION
  NATURAL_LANGUAGE_QUERY
  CUSTOM
}
model AIInsight {
  id           String   @id @default(cuid())
  userId       String
  insightType  String
  title        String
  query        String?  @db.Text
  response     String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([expiresAt])
  @@map("ai_insights")
}



